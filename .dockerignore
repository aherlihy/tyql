# Per-run outputs (will be regenerated by run_all_bench.sh).
bench_*.out
bench/benchmark_out_*.csv
bench/memory_usage.csv
bench/profiling_output.json
bench/profiling-results.json

# sbt / Scala build artifacts (will be rebuilt inside the image).
target/
bench/target/
project/target/
project/project/
bench/project/target/
bench/project/project/
src/main/scala/repro/project/
.bsp/
.bloop/
.metals/

# Results from previous reproducibility runs.
results/

# Crash reports from local JVM runs.
hs_err_pid*.log

# Large dataset archives — reviewers fetch medium/large data from Zenodo and
# bind-mount into the container. Small data lives under bench/data/<q>/data/
# and IS included.
rr-data.zip
bench/data/data-repro.zip
bench/data/*/m_data/
bench/data/*/l_data/
bench/data/orbits/og-data/

# Author workspace (response docs, old xlsx variants, stray files).
backup/
oopsla25-response.md
popl-response.md
output*.txt
cat
echo
tyql-response-updated-*.xlsx
test_database/

# VCS + editor metadata.
.git/
.gitignore
.idea/
.vscode/
.DS_Store

# Docker context self-reference (no need to copy the image build files into
# the container).
.dockerignore
